# Copy this file to .env.local (local dev) or .env (production Docker).
# NEVER commit .env or .env.local — they are gitignored.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Groq (LLM, free tier) ---
GROQ_API_KEY=gsk_...
# Self-hosted: use the larger model (no 10s Vercel cap)
GROQ_MODEL=llama-3.3-70b-versatile

# --- Jina AI (embeddings, free tier ~1M tokens/mo) ---
JINA_API_KEY=jina_...

# --- App ---
NEXT_PUBLIC_APP_URL=https://ragify.tech

# --- Self-host (Docker + Caddy on VM1) ---
# Public domain — Caddy uses this for auto HTTPS
# DOMAIN=helply.yourdomain.com

# --- Redis (self-host on VM2) ---
# VM1 app connects to VM2 private IP:
# REDIS_URL=redis://10.0.0.13:6379
# VM2 worker compose — bind Redis to private IP (not 0.0.0.0):
# REDIS_BIND=10.0.0.13

# --- Rate limiting ---
# Prefer REDIS_URL (local Redis on VM2). Upstash is optional fallback:
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=
# Random 32+ char secret for HMAC visitor IDs — run: openssl rand -hex 32
RATE_LIMIT_SECRET=
# Set to true temporarily while testing to bypass rate limits
# DISABLE_RATE_LIMIT=false

# --- Cron / worker ---
# CRON_SECRET=          # optional if using HTTP cron routes
# WORKER_POLL_MS=60000   # VM2 crawl worker interval
# WORKER_BATCH_SIZE=5

# --- Lemon Squeezy (billing) ---
LEMON_WEBHOOK_SECRET=

# --- Sentry (observability) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Quota alert emails (optional, via Resend free tier) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Helply <notifications@yourdomain.com>
