# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local — it's gitignored.

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGc...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGc...

# --- Groq (LLM, free tier) ---
GROQ_API_KEY=gsk_...

# --- Jina AI (embeddings, free tier ~1M tokens/mo) ---
JINA_API_KEY=jina_...

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Security (Phase 1) ---
# Upstash Redis — free tier at https://upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
# Random 32+ char secret for HMAC visitor IDs — run: openssl rand -hex 32
RATE_LIMIT_SECRET=

# --- Cron jobs (Phase 3/4) ---
# Random secret — Vercel cron sends: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# --- Lemon Squeezy (Phase 2 billing) ---
LEMON_WEBHOOK_SECRET=

# --- Sentry (Phase 4 observability) ---
NEXT_PUBLIC_SENTRY_DSN=

# --- Quota alert emails (optional, via Resend free tier) ---
RESEND_API_KEY=
RESEND_FROM_EMAIL=Helply <notifications@yourdomain.com>
