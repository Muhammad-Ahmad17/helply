# =============================================================================
# VM2 — helply-worker (Redis + worker + crawl-api + webhooks + cron)
# Copy:  cp .env.example .env  &&  nano .env
# Deploy: cd ~/helply/deploy/vm2 && docker compose up -d --build
# =============================================================================

# Redis bind — use this VM's private IP (VCN only, not 0.0.0.0)
REDIS_BIND=10.0.2.46

# --- Supabase (same project as VM1) ---
NEXT_PUBLIC_SUPABASE_URL=https://abcdefghijklmnop.supabase.co
SUPABASE_URL=https://abcdefghijklmnop.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWprbG1ub3AiLCJyb2xlIjoiYW5vbiIsImlhdCI6MTcw0000000LCJleHAiOjIwMTAwMDAwMDB9.MOCK_ANON_KEY_REPLACE_ME
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWprbG1ub3AiLCJyb2xlIjoic2VydmljZV9yb2xlIiwiaWF0IjoxNzAwMDAwMDAwLCJleHAiOjIwMTAwMDAwMDB9.MOCK_SERVICE_ROLE_KEY_REPLACE_ME

# --- Embeddings (crawl-api + worker) ---
JINA_API_KEY=jina_MOCK_JINA_KEY_REPLACE_ME

# --- Cron service (health-check probes Groq) ---
GROQ_API_KEY=gsk_MOCK_GROQ_KEY_REPLACE_ME

# Generate: openssl rand -hex 32
CRON_SECRET=mock_cron_secret_fedcba0987654321fedcba0987654321fedcba09

# Lemon Squeezy billing webhooks (optional)
LEMON_WEBHOOK_SECRET=mock_lemon_webhook_secret_replace_me

# --- Worker poller ---
WORKER_POLL_MS=60000
WORKER_BATCH_SIZE=5
