# =============================================================================
# VM1 — helply-app (Caddy + SPA + chat-api)
# Copy:  cp .env.example .env  &&  nano .env
# Deploy: cd ~/helply/deploy/vm1 && docker compose up -d --build
# =============================================================================

# --- Edge / routing ---
DOMAIN=ragify.tech
VM2_PRIVATE_IP=10.0.2.46

