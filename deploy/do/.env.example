# DigitalOcean droplet (deploy/do)
DOMAIN=ragify.tech
VITE_APP_URL=https://ragify.tech

# Bind Postgres/Redis to public IP only when OCI workers need access (set via Terraform firewall)
POSTGRES_BIND=0.0.0.0
REDIS_BIND=0.0.0.0
POSTGRES_PASSWORD=change-me
REDIS_PASSWORD=change-me
DATABASE_URL=postgresql://ragify:change-me@postgres:5432/ragify
REDIS_URL=redis://:change-me@redis:6379

# Clerk
CLERK_SECRET_KEY=sk_test_...
CLERK_PUBLISHABLE_KEY=pk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_STARTER_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# LLM
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.1-8b-instant

# Embeddings (OCI embed service URL)
EMBED_URL=http://YOUR_OCI_EMBED_IP:8080
EMBED_API_KEY=change-me-embed-key

# Zyte (optional fallback)
ZYTE_API_KEY=

# Observability
SENTRY_DSN=
DD_API_KEY=
DD_SITE=datadoghq.com

# Cron
CRON_SECRET=change-me-cron

# DO Spaces backups (optional profile: backup)
SPACES_ENDPOINT=https://nyc3.digitaloceanspaces.com
SPACES_BUCKET=ragify-backups
SPACES_ACCESS_KEY=
SPACES_SECRET_KEY=
