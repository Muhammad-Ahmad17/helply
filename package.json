{
  "name": "ragify",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ragify/app",
    "build": "npm run build -w @ragify/app",
    "start": "npm run start -w @ragify/app",
    "lint": "npm run lint -w @ragify/app",
    "typecheck": "npm run typecheck -w @ragify/app && npm run typecheck -w @ragify/worker",
    "worker": "npm run start -w @ragify/worker"
  }
}
