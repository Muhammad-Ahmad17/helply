{
  "name": "ragify",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @ragify/web",
    "dev:chat": "npm run dev -w @ragify/chat-api",
    "dev:crawl": "npm run dev -w @ragify/crawl-api",
    "build": "npm run build -w @ragify/web",
    "typecheck": "npm run typecheck -ws --if-present",
    "worker": "npm run start -w @ragify/worker"
  }
}
