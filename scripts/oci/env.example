# Helply OCI provisioning — copy to env.local and fill in values.
# Usage: source scripts/oci/env.local  (or provision-all.sh loads it automatically)

# Required — find in OCI Console → Identity → Compartments
HELPLY_COMPARTMENT_OCID=ocid1.compartment.oc1..aaaaaaa...

# Region (must match `oci setup config`, e.g. ap-mumbai-1, us-ashburn-1)
HELPLY_REGION=ap-mumbai-1

# VCN CIDR for helply-vcn
HELPLY_VCN_CIDR=10.0.0.0/16
HELPLY_APP_SUBNET_CIDR=10.0.1.0/24
HELPLY_WORKER_SUBNET_CIDR=10.0.2.0/24

# SSH public key file (used for both instances)
HELPLY_SSH_PUBLIC_KEY_FILE=~/.ssh/id_ed25519.pub

# Instance shape — pick ONE:
#   VM.Standard.E2.1.Micro  (AMD, 1 GB — always free)
#   VM.Standard.A1.Flex     (ARM, configure OCPUs/RAM below — free tier pool)
HELPLY_INSTANCE_SHAPE=VM.Standard.E2.1.Micro

# Only used when HELPLY_INSTANCE_SHAPE=VM.Standard.A1.Flex
HELPLY_A1_OCPUS=1
HELPLY_A1_MEMORY_GB=6

# Ubuntu 24.04 (auto-resolved at provision time if empty)
# HELPLY_UBUNTU_IMAGE_OCID=

# Resource display names (meaningful, do not change after provision)
HELPLY_VCN_NAME=helply-vcn
HELPLY_APP_SUBNET_NAME=helply-app-subnet
HELPLY_WORKER_SUBNET_NAME=helply-worker-subnet
HELPLY_IGW_NAME=helply-internet-gateway
HELPLY_ROUTE_TABLE_NAME=helply-public-route-table
HELPLY_APP_SECURITY_LIST_NAME=helply-app-security-list
HELPLY_WORKER_SECURITY_LIST_NAME=helply-worker-security-list
HELPLY_APP_INSTANCE_NAME=helply-app
HELPLY_WORKER_INSTANCE_NAME=helply-worker

# State file written after provision (OCIDs + IPs)
HELPLY_STATE_FILE=scripts/oci/.state.env
